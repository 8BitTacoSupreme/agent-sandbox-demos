#!/usr/bin/env bash
# =============================================================================
# agent-sbx — kernel-level sandbox for AI coding agents
# =============================================================================
# Tool-agnostic. Works downstream of Flox, devbox, mise, asdf, direnv, or
# plain Homebrew/apt. Inspired by sandflox; designed for portability.
#
# Two enforcement tiers:
#   Shell tier — PATH wipe + symlink farm + function armor
#   Kernel tier — sandbox-exec on macOS, bwrap+Landlock on Linux
#
# Usage:
#   agent-sbx prepare          # generate .sandbox/{bin,profile.sb,armor.bash}
#   agent-sbx elevate          # re-exec current shell under kernel sandbox
#   agent-sbx -- <cmd>         # run cmd inside fresh sandboxed shell
#   agent-sbx validate         # dry-run; print what would be enforced
#   agent-sbx status           # report active enforcement state
# =============================================================================

set -euo pipefail

SBX_DIR=".sandbox"
REQUISITES="${SBX_REQUISITES:-requisites.txt}"
POLICY="${SBX_POLICY:-policy.toml}"
PLATFORM="$(uname)"

# Standard paths every macOS binary needs to read.
SYS_READ_PATHS_DARWIN=(
  /usr/lib /usr/share /usr/libexec
  /System/Library
  /private/etc /private/var/db /private/var/folders
  /dev/null /dev/urandom /dev/zero /dev/random /dev/tty /dev/dtracehelper
  /Library/Preferences
)

# Standard paths every Linux binary needs to read.
SYS_READ_PATHS_LINUX=(
  /usr /lib /lib64 /etc /bin /sbin
  /dev/null /dev/urandom /dev/zero /dev/random /dev/tty
  /proc /sys/kernel/security
  /nix
)

# Standard paths denied by default (credentials).
DENIED_PATHS=(
  "$HOME/.ssh"
  "$HOME/.gnupg"
  "$HOME/.aws"
  "$HOME/.config/gcloud"
  "$HOME/.config/gh"
  "$HOME/.netrc"
  "$HOME/.kube"
)

# Package managers blocked by function armor (shell tier).
BLOCKED_MANAGERS=(
  flox nix nix-env nix-store nix-shell nix-build
  apt apt-get yum dnf brew snap flatpak
  pip pip3 npm npx yarn pnpm cargo go gem composer uv
  docker podman
)

# ─────────────────────────────────────────────────────────────────────────────
# usage / help
# ─────────────────────────────────────────────────────────────────────────────

usage() {
  cat <<'EOF'
agent-sbx — kernel-level sandbox for AI coding agents

USAGE
    agent-sbx <command> [args]
    agent-sbx -- <cmd> [args]    # shorthand for elevate + run

COMMANDS
    prepare              Generate .sandbox/ artifacts (bin/, profile.sb, armor.bash)
    elevate              Re-exec current shell under kernel sandbox
    validate             Dry-run — show what would be enforced
    status               Report active sandbox state
    help                 Show this message

CONFIG
    requisites.txt       List of binaries to allowlist (one per line)
    policy.toml          Workspace + denied paths + network mode

EXIT CODES
    0   success
    1   misuse / config error
    126 blocked by sandbox (shell tier)
EOF
}

# ─────────────────────────────────────────────────────────────────────────────
# helpers
# ─────────────────────────────────────────────────────────────────────────────

die() { echo "[agent-sbx] error: $*" >&2; exit 1; }
say() { echo "[agent-sbx] $*" >&2; }

# Read a key from policy.toml. Tiny TOML reader — handles flat string keys.
toml_get() {
  local key="$1" default="${2:-}"
  [[ -f "$POLICY" ]] || { echo "$default"; return; }
  grep -E "^[[:space:]]*${key}[[:space:]]*=" "$POLICY" 2>/dev/null \
    | head -1 \
    | sed -E "s/^[^=]*=[[:space:]]*\"?([^\"]*)\"?[[:space:]]*$/\1/" \
    || echo "$default"
}

# Read a TOML boolean. Returns 0 (true) or 1 (false).
toml_bool() {
  local val
  val="$(toml_get "$1" "${2:-false}")"
  [[ "$val" == "true" ]]
}

# Find absolute path of a binary on the current PATH.
resolve_binary() {
  local name="$1"
  local path
  path="$(command -v "$name" 2>/dev/null || true)"
  [[ -z "$path" ]] && return 1
  # Resolve symlinks to actual binary
  if command -v readlink >/dev/null 2>&1; then
    if readlink -f "$path" >/dev/null 2>&1; then
      readlink -f "$path"
    else
      # macOS readlink doesn't have -f without coreutils
      python3 -c "import os,sys; print(os.path.realpath(sys.argv[1]))" "$path" 2>/dev/null || echo "$path"
    fi
  else
    echo "$path"
  fi
}

# Get unique parent directories from a list of file paths.
unique_parents() {
  local paths=("$@")
  printf '%s\n' "${paths[@]}" | xargs -n1 dirname 2>/dev/null | sort -u
}

# ─────────────────────────────────────────────────────────────────────────────
# Linux platform probes
# ─────────────────────────────────────────────────────────────────────────────

# Check if bwrap is available and can create namespaces.
check_bwrap_available() {
  command -v bwrap >/dev/null 2>&1 || return 1
  # Smoke test: can we actually create a minimal namespace?
  bwrap --ro-bind / / -- /bin/true 2>/dev/null || return 1
  return 0
}

# Read Landlock ABI version. Returns 0 if Landlock is unavailable.
check_landlock_abi() {
  local abi_file="/sys/kernel/security/landlock/abi_version"
  if [[ -r "$abi_file" ]]; then
    cat "$abi_file" 2>/dev/null || echo 0
  else
    echo 0
  fi
}

# ─────────────────────────────────────────────────────────────────────────────
# prepare — generate .sandbox/ artifacts
# ─────────────────────────────────────────────────────────────────────────────

cmd_prepare() {
  [[ -f "$REQUISITES" ]] || die "$REQUISITES not found. Run 'agent-sbx init' or create one."

  say "Preparing sandbox in $SBX_DIR/"
  mkdir -p "$SBX_DIR/bin"

  # Pass 1: resolve every requisite to an absolute path.
  # Shell builtins (cd, test, etc.) are part of bash, not separate binaries —
  # skip them silently.
  local builtins=" cd test [ pwd echo : true false alias unalias type "
  local resolved=() missing=()
  while IFS= read -r line; do
    line="${line%%#*}"  # strip comments
    line="${line//[[:space:]]/}"
    [[ -z "$line" ]] && continue
    [[ "$builtins" == *" $line "* ]] && continue  # skip builtins
    local abs
    if abs=$(resolve_binary "$line"); then
      resolved+=("$line:$abs")
    else
      missing+=("$line")
    fi
  done < "$REQUISITES"

  if [[ ${#missing[@]} -gt 0 ]]; then
    say "WARNING: not on PATH (skipped): ${missing[*]}"
  fi

  # Pass 2: build symlink farm.
  rm -f "$SBX_DIR"/bin/*
  local bin_paths=()
  for entry in "${resolved[@]}"; do
    local name="${entry%%:*}" abs="${entry##*:}"
    ln -sf "$abs" "$SBX_DIR/bin/$name"
    bin_paths+=("$abs")
  done
  say "Symlinked ${#resolved[@]} binaries into $SBX_DIR/bin/"

  # Pass 3: discover unique read paths from binary parents (typically
  # a few /nix/store entries, or /opt/homebrew/bin, or /usr/bin).
  local read_paths
  read_paths=$(unique_parents "${bin_paths[@]}")

  # Pass 4: generate platform-specific kernel profile.
  case "$PLATFORM" in
    Darwin)
      generate_sbpl "$read_paths" > "$SBX_DIR/profile.sb"
      say "Wrote $SBX_DIR/profile.sb"
      ;;
    Linux)
      generate_bwrap_args "$read_paths" > "$SBX_DIR/bwrap.args"
      say "Wrote $SBX_DIR/bwrap.args"
      # Also write SBPL for reference/documentation
      generate_sbpl "$read_paths" > "$SBX_DIR/profile.sb"
      ;;
  esac

  # Pass 5: generate function armor.
  generate_armor > "$SBX_DIR/armor.bash"
  say "Wrote $SBX_DIR/armor.bash"

  # Pass 6: a manifest for status/validate.
  local landlock_abi=0
  [[ "$PLATFORM" == "Linux" ]] && landlock_abi="$(check_landlock_abi)"
  {
    echo "# agent-sbx manifest — generated $(date -u +%Y-%m-%dT%H:%M:%SZ)"
    echo "platform=$PLATFORM"
    echo "tools=${#resolved[@]}"
    echo "missing=${#missing[@]}"
    echo "policy=$POLICY"
    echo "network=$(toml_get network blocked)"
    echo "filesystem=$(toml_get filesystem workspace)"
    [[ "$PLATFORM" == "Linux" ]] && echo "landlock_abi=$landlock_abi"
  } > "$SBX_DIR/manifest"

  say "Done. Run 'agent-sbx elevate' to add kernel enforcement."
}

# ─────────────────────────────────────────────────────────────────────────────
# generate_sbpl — emit Seatbelt profile (macOS)
# ─────────────────────────────────────────────────────────────────────────────

generate_sbpl() {
  local read_paths="$1"
  local workspace
  workspace="$(pwd)"
  local network_mode
  network_mode="$(toml_get network blocked)"
  local fs_mode
  fs_mode="$(toml_get filesystem workspace)"

  cat <<SBPL
;; Generated by agent-sbx — do not edit by hand
(version 1)
(deny default)

;; Process control — required for any binary to run
(allow process-fork)
(allow process-exec)
(allow signal (target self))
(allow sysctl-read)
(allow mach-lookup)
(allow ipc-posix-shm)

;; ── Filesystem reads: system + binary directories ──
(allow file-read*
SBPL

  # System paths
  for p in "${SYS_READ_PATHS_DARWIN[@]}"; do
    echo "  (subpath \"$p\")"
  done

  # Binary parent paths (resolved from requisites)
  while IFS= read -r p; do
    [[ -n "$p" ]] && echo "  (subpath \"$p\")"
  done <<< "$read_paths"

  # Workspace read
  echo "  (subpath \"$workspace\")"

  # User HOME read for benign config (terminfo, locale)
  echo "  (literal \"$HOME/.bashrc\")"
  echo "  (literal \"$HOME/.zshrc\")"
  echo "  (literal \"$HOME/.profile\")"
  echo "  (subpath \"$HOME/.terminfo\")"

  cat <<SBPL
)

;; ── Filesystem writes ──
SBPL

  case "$fs_mode" in
    permissive)
      echo "(allow file-write*)"
      ;;
    strict)
      echo "(allow file-write* (subpath \"/private/tmp\"))"
      echo "(allow file-write* (subpath \"/private/var/folders\"))"
      ;;
    workspace|*)
      echo "(allow file-write* (subpath \"$workspace\"))"
      echo "(allow file-write* (subpath \"/private/tmp\"))"
      echo "(allow file-write* (subpath \"/private/var/folders\"))"
      ;;
  esac

  cat <<SBPL

;; ── Denied credential paths ──
(deny file-read*
SBPL

  for p in "${DENIED_PATHS[@]}"; do
    echo "  (subpath \"$p\")"
  done

  cat <<SBPL
)

;; ── Network ──
SBPL

  case "$network_mode" in
    unrestricted)
      echo "(allow network*)"
      ;;
    blocked|*)
      echo "(deny network*)"
      echo "(allow network* (local ip))"
      echo "(allow network-bind (local ip))"
      ;;
  esac
}

# ─────────────────────────────────────────────────────────────────────────────
# generate_bwrap_args — emit bwrap command-line arguments (Linux)
# ─────────────────────────────────────────────────────────────────────────────

generate_bwrap_args() {
  local read_paths="$1"
  local workspace
  workspace="$(pwd)"
  local network_mode
  network_mode="$(toml_get network blocked)"
  local fs_mode
  fs_mode="$(toml_get filesystem workspace)"
  local allow_localhost
  allow_localhost="$(toml_get allow-localhost true)"

  # Namespace and lifecycle flags
  echo "--die-with-parent"
  echo "--new-session"
  echo "--unshare-pid"
  echo "--unshare-uts"
  echo "--unshare-ipc"

  # Network namespace — only if network=blocked AND no localhost needed
  # (bwrap --unshare-net blocks ALL networking including loopback)
  if [[ "$network_mode" == "blocked" && "$allow_localhost" != "true" ]]; then
    echo "--unshare-net"
  fi

  # /proc and /dev
  echo "--proc"
  echo "/proc"
  echo "--dev"
  echo "/dev"

  # System read-only bind mounts
  for sys_path in /usr /lib /lib64 /etc /bin /sbin; do
    [[ -d "$sys_path" ]] && echo "--ro-bind" && echo "$sys_path" && echo "$sys_path"
  done

  # Nix store (if present)
  [[ -d /nix ]] && echo "--ro-bind" && echo "/nix" && echo "/nix"

  # Binary parent directories from resolved requisites
  while IFS= read -r p; do
    if [[ -n "$p" ]]; then
      echo "--ro-bind"
      echo "$p"
      echo "$p"
    fi
  done <<< "$read_paths"

  # Credential masking — bind /dev/null over sensitive paths
  for p in "${DENIED_PATHS[@]}"; do
    if [[ -e "$p" ]]; then
      echo "--ro-bind"
      echo "/dev/null"
      echo "$p"
    fi
  done

  # Workspace mount — mode depends on fs policy
  case "$fs_mode" in
    permissive)
      echo "--bind"
      echo "$workspace"
      echo "$workspace"
      ;;
    strict)
      echo "--ro-bind"
      echo "$workspace"
      echo "$workspace"
      ;;
    workspace|*)
      echo "--bind"
      echo "$workspace"
      echo "$workspace"
      ;;
  esac

  # Temp directory
  echo "--tmpfs"
  echo "/tmp"

  # HOME directory (read-only for shell configs)
  echo "--ro-bind"
  echo "$HOME/.bashrc"
  echo "$HOME/.bashrc"
  echo "--ro-bind"
  echo "$HOME/.profile"
  echo "$HOME/.profile"
}

# ─────────────────────────────────────────────────────────────────────────────
# generate_armor — shell function armor for package managers
# ─────────────────────────────────────────────────────────────────────────────

generate_armor() {
  cat <<'HEADER'
# Generated by agent-sbx — source from your shell init when entering the sandbox.
# Provides parseable [agent-sbx] BLOCKED messages so agents know what failed.

HEADER

  for mgr in "${BLOCKED_MANAGERS[@]}"; do
    cat <<ARMOR
function $mgr {
  echo "[agent-sbx] BLOCKED: $mgr is not available. Environment is immutable." >&2
  return 126
}
ARMOR
  done

  cat <<'FOOTER'

# Block python escape vectors
function python3 {
  for arg in "$@"; do
    case "$arg" in
      -m) shift
          case "${1:-}" in
            pip|ensurepip|venv)
              echo "[agent-sbx] BLOCKED: python3 -m $1 is not available." >&2
              return 126 ;;
          esac
          set -- -m "$@" ;;
    esac
  done
  command python3 "$@"
}

# Sentinel for status command
export SBX_ACTIVE=1
FOOTER
}

# ─────────────────────────────────────────────────────────────────────────────
# elevate — re-exec current shell under kernel sandbox
# ─────────────────────────────────────────────────────────────────────────────

cmd_elevate() {
  if [[ "${SBX_ACTIVE:-0}" == "1" ]]; then
    say "Already sandboxed — nothing to do."
    return 0
  fi

  case "$PLATFORM" in
    Darwin) cmd_elevate_darwin "$@" ;;
    Linux)  cmd_elevate_linux "$@" ;;
    *)      die "Unsupported platform: $PLATFORM" ;;
  esac
}

cmd_elevate_darwin() {
  [[ -f "$SBX_DIR/profile.sb" ]] || die "Run 'agent-sbx prepare' first."

  if ! command -v sandbox-exec >/dev/null 2>&1; then
    die "sandbox-exec not found. Is this macOS?"
  fi

  say "Elevating: re-exec $SHELL under sandbox-exec"

  local shell_name
  shell_name="$(basename "$SHELL")"

  case "$shell_name" in
    zsh)
      # zsh doesn't support --rcfile. Use ZDOTDIR to point at a directory
      # containing a .zshrc that sources our armor.
      local zdot="$SBX_DIR/zdot"
      mkdir -p "$zdot"
      echo "source \"$(pwd)/$SBX_DIR/armor.bash\"" > "$zdot/.zshrc"
      exec env \
        SBX_ACTIVE=1 \
        PATH="$(pwd)/$SBX_DIR/bin" \
        SHELL="$SHELL" \
        ZDOTDIR="$(pwd)/$zdot" \
        sandbox-exec -f "$SBX_DIR/profile.sb" "$SHELL"
      ;;
    *)
      exec env \
        SBX_ACTIVE=1 \
        PATH="$(pwd)/$SBX_DIR/bin" \
        SHELL="$SHELL" \
        sandbox-exec -f "$SBX_DIR/profile.sb" "$SHELL" --rcfile "$SBX_DIR/armor.bash"
      ;;
  esac
}

cmd_elevate_linux() {
  [[ -f "$SBX_DIR/bwrap.args" ]] || [[ -f "$SBX_DIR/profile.sb" ]] || \
    die "Run 'agent-sbx prepare' first."

  local has_bwrap=false has_landlock=false landlock_abi=0

  if check_bwrap_available; then
    has_bwrap=true
    say "bwrap: available"
  else
    say "WARNING: bwrap not available — falling back to shell-only enforcement"
  fi

  landlock_abi="$(check_landlock_abi)"
  if [[ "$landlock_abi" -ge 1 ]]; then
    has_landlock=true
    say "Landlock: ABI v$landlock_abi"
    [[ "$landlock_abi" -ge 4 ]] && say "Landlock: network enforcement available (ABI >= 4)"
  else
    say "WARNING: Landlock not available (kernel too old or LSM disabled)"
  fi

  # ── Build the execution chain ──

  local workspace
  workspace="$(pwd)"
  local fs_mode
  fs_mode="$(toml_get filesystem workspace)"
  local network_mode
  network_mode="$(toml_get network blocked)"

  # Start with the shell invocation
  local shell_name
  shell_name="$(basename "${SHELL:-/bin/bash}")"
  local shell_cmd=("${SHELL:-/bin/bash}")
  case "$shell_name" in
    zsh)
      local zdot="$SBX_DIR/zdot"
      mkdir -p "$zdot"
      echo "source \"$(pwd)/$SBX_DIR/armor.bash\"" > "$zdot/.zshrc"
      ;;
    *)
      shell_cmd+=("--rcfile" "$SBX_DIR/armor.bash")
      ;;
  esac

  # Layer 1: Landlock (innermost — applied to the process before exec)
  local landlock_prefix=()
  if [[ "$has_landlock" == true ]] && command -v sbx-landlock >/dev/null 2>&1; then
    landlock_prefix=(sbx-landlock
      "--fs-mode=$fs_mode"
      "--workspace=$workspace"
    )

    # Build denied paths arg
    local denied_csv=""
    for p in "${DENIED_PATHS[@]}"; do
      [[ -n "$denied_csv" ]] && denied_csv+=","
      denied_csv+="$p"
    done
    [[ -n "$denied_csv" ]] && landlock_prefix+=("--denied=$denied_csv")

    # Writable paths
    landlock_prefix+=("--writable=$workspace,/tmp")

    # Read-only overrides
    landlock_prefix+=("--read-only=$workspace/.git,$workspace/policy.toml")

    # Network mode (ABI >= 4 only)
    if [[ "$landlock_abi" -ge 4 && "$network_mode" == "blocked" ]]; then
      landlock_prefix+=("--network=blocked")
    fi

    landlock_prefix+=(--)
    say "Elevating: Landlock LSM + bwrap namespaces"
  elif [[ "$has_landlock" == true ]]; then
    say "WARNING: sbx-landlock not on PATH — skipping Landlock enforcement"
  fi

  # Layer 2: bwrap (outermost — namespace isolation)
  if [[ "$has_bwrap" == true ]]; then
    local bwrap_args=()
    while IFS= read -r arg; do
      bwrap_args+=("$arg")
    done < "$SBX_DIR/bwrap.args"

    local env_args=(
      SBX_ACTIVE=1
      "PATH=$(pwd)/$SBX_DIR/bin"
      "SHELL=${SHELL:-/bin/bash}"
    )
    [[ "$shell_name" == "zsh" ]] && env_args+=("ZDOTDIR=$(pwd)/$SBX_DIR/zdot")

    exec env "${env_args[@]}" \
      bwrap "${bwrap_args[@]}" -- \
      "${landlock_prefix[@]}" "${shell_cmd[@]}"
  elif [[ ${#landlock_prefix[@]} -gt 0 ]]; then
    # Landlock-only (no bwrap)
    say "Elevating: Landlock-only (no namespace isolation)"
    local env_args=(
      SBX_ACTIVE=1
      "PATH=$(pwd)/$SBX_DIR/bin"
      "SHELL=${SHELL:-/bin/bash}"
    )
    [[ "$shell_name" == "zsh" ]] && env_args+=("ZDOTDIR=$(pwd)/$SBX_DIR/zdot")

    exec env "${env_args[@]}" \
      "${landlock_prefix[@]}" "${shell_cmd[@]}"
  else
    # Shell-only fallback
    say "Elevating: shell-only enforcement (no kernel sandbox)"
    local env_args=(
      SBX_ACTIVE=1
      "PATH=$(pwd)/$SBX_DIR/bin"
      "SHELL=${SHELL:-/bin/bash}"
    )
    [[ "$shell_name" == "zsh" ]] && env_args+=("ZDOTDIR=$(pwd)/$SBX_DIR/zdot")

    exec env "${env_args[@]}" "${shell_cmd[@]}"
  fi
}

# ─────────────────────────────────────────────────────────────────────────────
# validate — dry-run inspector
# ─────────────────────────────────────────────────────────────────────────────

cmd_validate() {
  [[ -f "$REQUISITES" ]] || die "$REQUISITES not found"
  [[ -f "$SBX_DIR/manifest" ]] || die "Run 'agent-sbx prepare' first."

  cat "$SBX_DIR/manifest"
  say "Allowlisted binaries: $(ls "$SBX_DIR/bin" 2>/dev/null | wc -l)"

  case "$PLATFORM" in
    Darwin)
      [[ -f "$SBX_DIR/profile.sb" ]] && \
        say "Profile: $SBX_DIR/profile.sb ($(wc -l < "$SBX_DIR/profile.sb") lines)"
      ;;
    Linux)
      [[ -f "$SBX_DIR/bwrap.args" ]] && \
        say "bwrap args: $SBX_DIR/bwrap.args ($(wc -l < "$SBX_DIR/bwrap.args") lines)"
      local abi
      abi="$(check_landlock_abi)"
      say "Landlock ABI: v$abi"
      if check_bwrap_available; then
        say "bwrap: available"
      else
        say "bwrap: not available"
      fi
      if command -v sbx-landlock >/dev/null 2>&1; then
        say "sbx-landlock: available"
      else
        say "sbx-landlock: not on PATH"
      fi
      ;;
  esac
}

# ─────────────────────────────────────────────────────────────────────────────
# status — runtime introspection
# ─────────────────────────────────────────────────────────────────────────────

cmd_status() {
  if [[ "${SBX_ACTIVE:-0}" == "1" ]]; then
    say "Active: kernel + shell enforcement"
  else
    say "Inactive: outside sandbox"
  fi
  say "Platform: $PLATFORM"
  [[ -f "$SBX_DIR/manifest" ]] && cat "$SBX_DIR/manifest"
}

# ─────────────────────────────────────────────────────────────────────────────
# init — emit example config
# ─────────────────────────────────────────────────────────────────────────────

cmd_init() {
  [[ -f "$REQUISITES" ]] && say "$REQUISITES exists, skipping" || \
    cat > "$REQUISITES" <<'EOF'
# Allowlisted binaries — one per line. Comments start with #.
bash
sh
cat
ls
echo
grep
sed
awk
head
tail
sort
uniq
wc
diff
find
git
jq
curl
python3
EOF

  [[ -f "$POLICY" ]] && say "$POLICY exists, skipping" || \
    cat > "$POLICY" <<'EOF'
[meta]
version = "1"

[network]
mode = "blocked"
allow-localhost = true

[filesystem]
mode = "workspace"
EOF

  say "Wrote $REQUISITES and $POLICY"
}

# ─────────────────────────────────────────────────────────────────────────────
# main dispatch
# ─────────────────────────────────────────────────────────────────────────────

CMD="${1:-help}"
[[ $# -gt 0 ]] && shift

case "$CMD" in
  prepare)  cmd_prepare "$@" ;;
  elevate)  cmd_elevate "$@" ;;
  validate) cmd_validate "$@" ;;
  status)   cmd_status "$@" ;;
  init)     cmd_init "$@" ;;
  --)
    cmd_prepare
    case "$PLATFORM" in
      Darwin)
        exec env SBX_ACTIVE=1 PATH="$(pwd)/$SBX_DIR/bin" \
          sandbox-exec -f "$SBX_DIR/profile.sb" "$@"
        ;;
      Linux)
        _bwrap_args=()
        if [[ -f "$SBX_DIR/bwrap.args" ]] && check_bwrap_available; then
          while IFS= read -r arg; do
            _bwrap_args+=("$arg")
          done < "$SBX_DIR/bwrap.args"
          exec env SBX_ACTIVE=1 PATH="$(pwd)/$SBX_DIR/bin" \
            bwrap "${_bwrap_args[@]}" -- "$@"
        else
          exec env SBX_ACTIVE=1 PATH="$(pwd)/$SBX_DIR/bin" "$@"
        fi
        ;;
      *)
        exec env SBX_ACTIVE=1 PATH="$(pwd)/$SBX_DIR/bin" "$@"
        ;;
    esac
    ;;
  help|-h|--help) usage ;;
  *) usage; exit 1 ;;
esac
