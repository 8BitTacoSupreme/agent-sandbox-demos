{
  "name": "agent-sbx-workspace",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "../../.."
  },
  "runArgs": [
    "--cap-add=SYS_ADMIN",
    "--security-opt=seccomp=unconfined"
  ],
  "remoteUser": "agent",
  "postCreateCommand": "agent-sbx prepare",
  "postAttachCommand": "echo '[agent-sbx] Run: agent-sbx elevate — to enter the sandbox'",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-vscode.cpptools"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "features": {},
  "forwardPorts": [],
  "mounts": []
}
